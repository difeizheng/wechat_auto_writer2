# ============================================================
# 微信公众号AI写作助手 - 环境配置模板
# ============================================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际需求填写配置项
# 3. 敏感信息请勿提交到版本控制系统
#
# ============================================================

# ------------------------------------------------------------
# AI 模型配置
# ------------------------------------------------------------

# 默认使用的AI模型：openai / claude / ollama / siliconflow
DEFAULT_AI_MODEL=openai

# OpenAI 配置（使用OpenAI模型时必需）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI模型名称（可选：gpt-4, gpt-4o-mini, gpt-3.5-turbo等）
OPENAI_MODEL=gpt-4o-mini

# Claude 配置（使用Claude模型时必需）
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
# Claude模型名称（可选：claude-3-opus, claude-3-haiku等）
CLAUDE_MODEL=claude-3-haiku-20240307

# SiliconFlow 配置（国内AI模型平台）
# 官网：https://siliconflow.cn
# 支持模型：Qwen、DeepSeek、GLM、Llama等
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SiliconFlow模型名称（常见选项）:
# - Qwen/Qwen2.5-7B-Instruct（推荐，免费额度）
# - Qwen/Qwen2.5-72B-Instruct（更强大）
# - deepseek-ai/DeepSeek-V2.5
# - THUDM/glm-4-9b-chat
# - meta-llama/Llama-3.1-8B-Instruct
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Ollama 配置（本地部署Ollama时使用）
OLLAMA_BASE_URL=http://localhost:11434
# Ollama模型名称（需要先下载：ollama pull llama3）
OLLAMA_MODEL=llama3

# ------------------------------------------------------------
# 微信公众号配置
# ------------------------------------------------------------ 
# 
# 获取方式：
# 1. 登录微信公众平台 https://mp.weixin.qq.com
# 2. 进入「开发 - 基本配置」
# 3. 获取 AppID 和 AppSecret
# ------------------------------------------------------------

WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ------------------------------------------------------------
# 钉钉机器人通知配置
# ------------------------------------------------------------
# 
# 获取方式：
# 1. 在钉钉群中添加机器人
# 2. 选择「自定义」机器人
# 3. 设置机器人名称
# 4. 安全设置选择「加签」（推荐）
# 5. 复制生成的 Webhook URL 和 密钥（SEC...）
# ------------------------------------------------------------
# Webhook URL（必需）
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-access-token

# 签名密钥（加签方式必需，如果选择其他安全方式可不填）
# 格式：SECxxxx...
DINGTALK_SECRET=SECyour-secret-key-here

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------

# 数据库文件路径（相对路径或绝对路径）
DATABASE_PATH=data/wechat_writer.db

# 调试模式：True / False
# 开启后输出详细日志，便于排查问题
DEBUG_MODE=False

# ------------------------------------------------------------
# 配置说明
# ------------------------------------------------------------
# 
# AI 模型选择建议：
# - openai: GPT-4/GPT-4o-mini，稳定可靠，需要API密钥（海外）
# - claude: Claude-3，擅长长文本和创意写作，需要API密钥（海外）
# - siliconflow: 国内平台，支持多种模型，性价比高，推荐国内用户使用
# - ollama: 本地部署，免费使用，需要安装Ollama并下载模型
#
# SiliconFlow 使用说明：
# 1. 注册账号：https://siliconflow.cn
# 2. 获取API Key：登录后在「API密钥」页面创建
# 3. 选择模型：根据需求选择合适的模型名称
# 4. 新用户有免费额度，适合测试和轻度使用
#
# 多模型同时配置：
# - 可以同时配置多个模型的API密钥
# - 运行时可以切换不同的模型
# - 使用 get_available_models() 查看可用模型
#
# 微信配置说明：
# - 初次使用可以先不配置微信
# - 微信配置用于上传文章到草稿箱
# - 配置后可使用完整的公众号管理功能
# ------------------------------------------------------------