# Streamlit Secrets 配置模板
# 
# 使用方法：
# 1. 本地开发：复制此文件为 .streamlit/secrets.toml 并填入真实值
# 2. Streamlit Cloud：在 Dashboard → Settings → Secrets 中粘贴以下内容
#
# 注意：secrets.toml 包含敏感信息，不要提交到 Git！

# ==================== AI模型配置 ====================

# 至少配置一种AI模型

# OpenAI 配置
OPENAI_API_KEY = "sk-xxx"
OPENAI_MODEL = "gpt-4o-mini"  # 可选：gpt-4o, gpt-4-turbo 等

# Claude 配置
# CLAUDE_API_KEY = "xxx"
# CLAUDE_MODEL = "claude-3-haiku-20240307"

# SiliconFlow 配置（推荐国内用户）
SILICONFLOW_API_KEY = "xxx"
SILICONFLOW_MODEL = "Qwen/Qwen2.5-7B-Instruct"  # 可选：deepseek-ai/DeepSeek-V2.5

# Ollama 本地模型配置
# OLLAMA_BASE_URL = "http://localhost:11434"
# OLLAMA_MODEL = "llama3"

# 默认使用的模型
DEFAULT_AI_MODEL = "siliconflow"  # openai / claude / siliconflow / ollama

# ==================== 微信公众号配置 ====================

WECHAT_APP_ID = "wxxxx"
WECHAT_APP_SECRET = "xxx"

# ==================== 钉钉通知配置（可选） ====================

# DINGTALK_WEBHOOK = "https://oapi.dingtalk.com/robot/send?access_token=xxx"
# DINGTALK_SECRET = "SECxxx"  # 加签密钥（如果机器人设置了加签验证）

# ==================== 应用配置 ====================

# DATABASE_PATH = "data/wechat_writer.db"
# DEBUG_MODE = "false"